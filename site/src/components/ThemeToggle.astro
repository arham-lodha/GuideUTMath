---
// Manual light/dark toggle. Honors `prefers-color-scheme` until the user
// clicks it; after that the choice is persisted in localStorage.
---
<button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle color theme">
  <span id="theme-toggle-label">Theme</span>
</button>

<script is:inline>
  (function () {
    const KEY = 'guide-ut-math-theme';
    const btn = document.getElementById('theme-toggle');
    const label = document.getElementById('theme-toggle-label');

    function current() {
      return document.documentElement.dataset.theme
        || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    }
    function setLabel() {
      if (!label) return;
      label.textContent = current() === 'dark' ? 'Light' : 'Dark';
    }
    setLabel();

    if (btn) {
      btn.addEventListener('click', () => {
        const next = current() === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        try { localStorage.setItem(KEY, next); } catch (_) {}
        setLabel();
      });
    }
  })();
</script>
