---
import { renderMarkdown } from '../lib/markdown';

type Props = {
  contributorName: string;
  contributorSlug: string;
  pronouns?: string;
  currentPosition?: string;
  date: string;
  sectionSlug: string;
  answer: string;
  placeholder?: boolean;
};

const {
  contributorName,
  contributorSlug,
  pronouns,
  currentPosition,
  date,
  sectionSlug,
  answer,
  placeholder,
} = Astro.props;

const base = import.meta.env.BASE_URL || '/';
const trimmedBase = base.endsWith('/') ? base.slice(0, -1) : base;
const linkHref = `${trimmedBase}/sections/${sectionSlug}/by-contributor/${contributorSlug}/`;

const html = renderMarkdown(answer);
---
<article class="card">
  <header class="card-header">
    <span class="who">
      <a href={linkHref}>{contributorName}</a>
      {pronouns && <span class="position"> ({pronouns})</span>}
      {currentPosition && <span class="position"> · {currentPosition}</span>}
      {placeholder && <span class="position"> · placeholder</span>}
    </span>
    <span class="date">{date}</span>
  </header>
  <div class="prose" set:html={html} />
  <footer class="card-footer">
    <a href={linkHref}>Read {contributorName}'s full response →</a>
  </footer>
</article>
