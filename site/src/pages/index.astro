---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Prose from '../components/Prose.astro';

const entry = await getEntry('docs', 'README');
if (!entry) throw new Error('Missing README.md at repo root.');
const { Content } = await render(entry);
---
<BaseLayout title="The Hitchhiker's Guide to UT Math">
  <Prose>
    <Content />
  </Prose>
</BaseLayout>
